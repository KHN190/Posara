5,290629,53,5,275,290721,57,6,275,290804,60,11,275,290827,41,17,306,290914,53,26,306,291047,57,6,281,291245,41,19,291,291453,53,5,291,291546,60,13,291,291667,35,19,299,291881,63,5,284,292083,54,19,292,292293,53,5,291,292380,60,11,291,292497,41,22,301,292715,35,5,281,292800,63,12,281,292917,53,20,291,293120,63,5,296,293335,35,15,285,293423,58,23,285,293537,42,5,291,293628,53,6,291,293715,60,10,291,293749,35,22,292,293957,63,5,700,294583,54,17,291,294667,60,20,291,294754,63,26,291];
  let n_ev = 2685;

  let SECDUR = [30000, 32000, 34000, 30000, 28000];

  let mut t0 = now();
  let mut idx = 0;
  let mut bass_note = 41;
  let mut sec = 0;
  let mut sec_t = t0 + SECDUR[0];
  let mut sub_t = t0 + 300;
  let mut pad_t = t0 + 60000;
  let mut hiss_t = t0;
  let mut scree_t = t0 + 40000;
  let mut crack_t = t0 + 12000;

  loop {
    let t = now();

    if t >= sec_t {
      sec = (sec + 1) % 5;
      sec_t = t + SECDUR[sec];
    };

    let pt = t - t0;
    if idx < n_ev {
      if EV[idx * 4] <= pt {
        let bn = EV[idx * 4 + 1];
        synth_on(0, bn, EV[idx * 4 + 2], EV[idx * 4 + 3]);
        if bn < 50 { bass_note = bn };
        idx = idx + 1
      } else { idx = idx }
    } else {
      idx = 0; t0 = t
    };

    if t >= sub_t {
      synth_on(1, bass_note - 12, 26 + ri(6), 7000);
      sub_t = t + 5000 + ri(3000)
    };

    if sec >= 2 && sec <= 3 {
      if t >= pad_t {
        synth_on(2, bass_note + 12, 24, 5000);
        synth_on(2, bass_note + 24, 18, 5000);
        pad_t = t + 5000 + ri(2000)
      }
    } else { pad_t = t + 1000 };

    if t >= hiss_t {
      synth_on(4, 60, 4 + ri(3) + (if sec == 3 { 3 } else { 0 }), 4200);
      hiss_t = t + 3000 + ri(2000)
    };

    if t >= scree_t {
      synth_filter(5, 2, 2400 + ri(1600), 42);
      synth_on(5, 75 + ri(7), 10 + ri(8) + (if sec == 3 { 4 } else { 0 }), 3800 + ri(2400));
      scree_t = t + (if sec == 3 { 16000 } else { 30000 }) + ri(20000);
    };

    if t >= crack_t {
      synth_filter(6, 2, 2600 + ri(3400), 14);
      synth_on(6, 60, 6 + ri(6), 18);
      crack_t = t + 1600 + ri(3600)
    };

    cls(0x0000);
    device_in(0x2001, 1);
    frame.present()
  }
}